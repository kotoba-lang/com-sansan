// Sansan clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace sansan {

    entity Account {
        id: string @unique
        name: string
        domain: string
        industry: string
        ownerId: string
        annualRevenue: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Contact {
        id: string @unique
        accountId: string
        firstName: string
        lastName: string
        email: string
        phone: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Lead {
        id: string @unique
        company: string
        email: string
        status: string
        source: string
        score: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Opportunity {
        id: string @unique
        accountId: string
        name: string
        stage: string
        amount: float
        closeDate: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Activity {
        id: string @unique
        subjectId: string
        type: string
        subject: string
        dueDate: datetime
        done: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Pipeline {
        id: string @unique
        name: string
        stageOrder: string
        ownerId: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
